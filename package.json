{
  "name": "@managelm/openclaw-plugin",
  "version": "1.0.0",
  "description": "Manage Linux & Windows servers from OpenClaw with natural language",
  "type": "module",
  "license": "Apache-2.0",
  "author": {
    "name": "ManageLM",
    "url": "https://www.managelm.com"
  },
  "homepage": "https://www.managelm.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/managelm/openclaw-plugin.git"
  },
  "keywords": [
    "openclaw",
    "managelm",
